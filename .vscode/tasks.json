{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sphinx Make",
            "type": "shell",
            "command": "cd ${workspaceFolder}/docs; make html; firefox build/html/index.html",
            "group": {
              "kind": "build",
              "isDefault": true
            }
        },
        {
            "label": "Create Docx",
            "type": "shell",
            "command": "cd ${workspaceFolder}; python3 src/portfolio/portfolio.py; soffice formatted_document.docx",
            "group": {
              "kind": "build",
              "isDefault": true
            }
        },
    ]
}
